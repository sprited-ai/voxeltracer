{
  "name": "@sprited/voxeltracer",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "MagicaVoxel path tracer for the web (WebGL2). Framework-agnostic library + demo app.",
  "type": "module",
  "main": "./dist/voxeltracer.umd.cjs",
  "module": "./dist/voxeltracer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/voxeltracer.js",
      "require": "./dist/voxeltracer.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": "git+https://github.com/sprited-ai/voxeltracer.git",
  "keywords": [],
  "author": "kndlt <kndlt22@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sprited-ai/voxeltracer/issues"
  },
  "homepage": "https://sprited-ai.github.io/voxeltracer",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build -c vite.lib.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "ndarray": "^1.0.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/ndarray": "^1.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
