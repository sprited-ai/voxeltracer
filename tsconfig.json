// Ref 1: https://webpack.js.org/guides/typescript/#basic-setup
{
  "compilerOptions": {
    "target": "esnext",
    "declaration": true,
    "sourceMap": true,
    // "allowJs": true,
    "skipLibCheck": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    // "isolatedModules": true,
    // "noEmit": true,
    "jsx": "react",
    "lib": ["esnext", "dom"],
    "outDir": "./dist"
  },
  "include": [
    "src"
  ]
}
